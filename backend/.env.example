# AutoQA Prompt Optimization System — Environment Variables
# Copy this file to .env and fill in your values before running.
# Never commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────────

# OpenAI API key — obtain from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Optional (defaults shown) ─────────────────────────────────────────────────

# OpenAI model for the evaluator (applies prompts to conversations — use your planned production model)
OPENAI_MODEL=gpt-4o

# OpenAI model for reasoning tasks (prompt optimization, RCA, ambiguity detection — use a more capable model)
OPENAI_OPTIMIZER_MODEL=gpt-4o

# Max concurrent LLM calls in the evaluator node (semaphore cap, max 20)
MAX_CONCURRENT_LLM_CALLS=5

# Number of rules bundled per LLM call in the evaluator (matches production batch size)
RULES_BATCH_SIZE=6

# Per-batch LLM call timeout in seconds (safety net — httpx timeout in get_llm fires first for slow calls)
LLM_CALL_TIMEOUT=1800

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Allowed CORS origins for the FastAPI backend (comma-separated)
CORS_ORIGINS=http://localhost:4200
