# AutoQA Prompt Optimization System — Environment Variables
# Copy this file to .env and fill in your values before running.
# Never commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────────

# OpenAI API key — obtain from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Optional (defaults shown) ─────────────────────────────────────────────────

# OpenAI model to use for all LLM calls (gpt-4o recommended; gpt-4o-mini for lower cost)
OPENAI_MODEL=gpt-4o

# Max concurrent LLM calls in the evaluator node (semaphore cap, max 20)
MAX_CONCURRENT_LLM_CALLS=5

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Allowed CORS origins for the FastAPI backend (comma-separated)
CORS_ORIGINS=http://localhost:4200
