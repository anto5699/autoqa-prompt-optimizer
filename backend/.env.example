# AutoQA Prompt Optimization System — Environment Variables
# Copy this file to .env and fill in your values before running.
# Never commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────────

# OpenAI API key — obtain from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Optional (defaults shown) ─────────────────────────────────────────────────

# OpenAI model for the evaluator (applies prompts to conversations — use your planned production model)
OPENAI_MODEL=gpt-4o

# OpenAI model for reasoning tasks (prompt optimization, RCA, ambiguity detection — use a more capable model)
OPENAI_OPTIMIZER_MODEL=gpt-4o

# Max concurrent LLM calls in the evaluator node (semaphore cap, max 20)
MAX_CONCURRENT_LLM_CALLS=5

# Number of rules bundled per LLM call in the evaluator (matches production batch size)
RULES_BATCH_SIZE=6

# Per-batch LLM call timeout in seconds (safety net — httpx timeout in get_llm fires first for slow calls)
LLM_CALL_TIMEOUT=1800

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Allowed CORS origins for the FastAPI backend (comma-separated)
CORS_ORIGINS=http://localhost:4200

# ── GT-alignment accommodations (defaults preserve prior behaviour) ─────────────

# Stagnation detection (centralised; used by the mid-loop GT alignment audit routing)
STAGNATION_WINDOW=3
STAGNATION_SPREAD=0.03
MIN_ITERS_BETWEEN_AUDITS=3

# No-progress early-stop: stop a below-target rule that stays flat for STALL_PATIENCE
# iterations AFTER a GT alignment audit has run (never halts an improving rule).
STALL_PATIENCE=3
MIN_IMPROVEMENT_DELTA=0.01

# Halt a rule when the GT alignment audit verdict is LABELLING_INCONSISTENCY
# (labels contradict the definition → relabel, don't keep rewriting). Set false to disable.
ENABLE_LABEL_LIMITED_HALT=true

# Consensus confidence on GT relabel proposals. RUNS=1 == single-judge (today's behaviour).
# Set RUNS>=3 and/or a distinct CONSENSUS_MODEL for independent cross-model confidence.
GT_AUDIT_CONSENSUS_RUNS=1
GT_AUDIT_CONSENSUS_MODEL=

# Metrics annotated low-confidence when the Yes/No evaluable count is below this (no status change)
MIN_EVALUABLE_N=10

# Per-prediction confidence (5a) — currently inert: activating it via the eval prompt would
# violate the fixed-system-prompt rule; a self-consistency implementation is deferred.
ENABLE_PREDICTION_CONFIDENCE=false
